# ─────────────────────────────────────────────────────────────────────────────
# GitHub Analytics Pipeline — Environment Variables Template
# Copy to .env and fill in your credentials. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub API ────────────────────────────────────────────────────────────────
# Create a PAT at: https://github.com/settings/tokens  (no scopes needed)
# With token: 5000 req/hr   Without: 60 req/hr (extremely limited)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_POLL_INTERVAL_SECONDS=5
GITHUB_PAGES=3
GITHUB_TRACK_REPOS=torvalds/linux,microsoft/vscode,openai/openai-python,huggingface/transformers,golang/go,rust-lang/rust,tensorflow/tensorflow,facebook/react,vuejs/vue,django/django

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_GITHUB=github-events

# ── Local Storage (used by streaming + batch) ─────────────────────────────────
# Streaming writes Parquet here; batch reads + enriches; loader uploads to Snowflake
GCS_EMULATOR_HOST=localhost:4443
GCS_BUCKET=github-analytics-raw
LOCAL_GCS_ROOT=./data/gcs-emulator

# ── Snowflake ─────────────────────────────────────────────────────────────────
# Sign up free at: https://signup.snowflake.com  ($400 trial credits)
# Account identifier format: <orgname>-<accountname>  (shown in Snowflake UI → Admin → Accounts)
SNOWFLAKE_ACCOUNT=your_org-your_account      # e.g. abc12345.us-east-1 or myorg-myaccount
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=GITHUB_PIPELINE
SNOWFLAKE_SCHEMA_RAW=RAW
SNOWFLAKE_SCHEMA_MART=MART

# ── dbt ───────────────────────────────────────────────────────────────────────
# dev  = DuckDB (local, no Snowflake needed)  |  prod = Snowflake
DBT_TARGET=dev
DBT_DUCKDB_PATH=./dbt/dev.duckdb
DBT_PROJECT_DIR=./dbt

# ── Data Paths ────────────────────────────────────────────────────────────────
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=github_analytics_secret_key_change_me

# ── Dashboard ─────────────────────────────────────────────────────────────────
STREAMLIT_REFRESH_SECONDS=30
